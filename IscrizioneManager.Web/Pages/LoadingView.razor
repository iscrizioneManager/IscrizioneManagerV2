<link href="css/LoadingView.css" rel="stylesheet" />
<div class="loading-overlay" style="display:@(IsVisible ? "flex" : "none")">
    <div class="loading-content">
        <h2>@Line1Text</h2>
        <p>@Line2Text</p>
    </div>
</div>

@code {
    private string Line1Text = "";
    private string Line2Text = "";
    private CancellationTokenSource? _cts;

    private readonly string[] _loadingMessages = new[]
    {
        "Sto preparando i dati",
        "Quasi pronto",
        "Caricamento in corso",
        "Attendere prego"
    };

    private readonly string[] _uselessTrivia = new[]
    {
        "Sapevi che nel 1960 il miglior giocatore di cricket del campionato indiano segnò 7 punti in una partita che durò 3 giorni?",
        "Lo sapevi che nel 1980 in Germania qualcuno brevettò scarpe con luci stroboscopiche integrate?",
        "Lo sapevi che in Brasile c’è una gara annuale di corsa con pentole in testa?",
        // aggiungi tutte le altre curiosità qui...
    };

    public bool IsVisible { get; private set; } = false;

    protected override void OnInitialized()
    {
        Start(); // facoltativo: parte subito
    }


    public void Start()
    {
        IsVisible = true;
        _cts = new CancellationTokenSource();
        AnimateLoading(_cts.Token);
    }

    public void Stop()
    {
        _cts?.Cancel();
        IsVisible = false;
        Line1Text = "";
        Line2Text = "";
        StateHasChanged();
    }

    private async void AnimateLoading(CancellationToken token)
    {
        var random = new Random();
        var dots = "";
        var message = _loadingMessages[random.Next(_loadingMessages.Length)];
        var uselessTrivia = _uselessTrivia[random.Next(_uselessTrivia.Length)];

        int triviaCounter = 0;
        int triviaChangeInterval = 10000; // 10 secondi
        var stopwatch = System.Diagnostics.Stopwatch.StartNew();
        bool pop = false;

        try
        {
            while (!token.IsCancellationRequested)
            {
                dots += ".";
                if (dots.Length > 3) dots = "";

                if (stopwatch.ElapsedMilliseconds - triviaCounter >= triviaChangeInterval)
                {
                    triviaCounter = (int)stopwatch.ElapsedMilliseconds;
                    uselessTrivia = _uselessTrivia[random.Next(_uselessTrivia.Length)];
                    pop = true;
                }

                Line1Text = message + dots;
                Line2Text = uselessTrivia;
                StateHasChanged();

                await Task.Delay(500, token);
            }
        }
        catch (TaskCanceledException)
        {
            // qui ignoriamo l'annullamento, nessun errore in console
        }
    }

}
