@using IscrizioneManager.Core.Models
@using IscrizioneManager.Web.Services
@using IscrizioniManager.Items
@using IscrizioniManager.Models
@using Newtonsoft.Json
<link href="css/ModuloIscrizioneView.css" rel="stylesheet" />

<EditForm Model="FormModel" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <LoadingView @ref="LoadingOverlay" />

    <div class="form-container @(IsLoading ? "hidden" : "")">
        <!-- ================= ANAGRAFICA ================= -->
        <div class="row-flex">
            <fieldset disabled="@IsReadOnly" class="no-border">
                <div class="field small">
                    <label>Cognome</label>
                    <InputText @bind-Value="FormModel.Cognome" class="form-control" />
                </div>
            </fieldset>
            <fieldset disabled="@IsReadOnly" class="no-border">

                <div class="field small">
                    <label>Nome</label>
                    <InputText @bind-Value="FormModel.Nome" class="form-control" />
                </div>
            </fieldset>
            <fieldset disabled="@IsReadOnly" class="no-border">
                <div class="field small">
                    <label>Data di nascita</label>
                    <InputDate @bind-Value="FormModel.DataNascita" class="form-control" />
                </div>
            </fieldset>
            <fieldset disabled="@IsReadOnly" class="no-border">
                <div class="field small">
                    <label>Genere</label>
                    <InputSelect @bind-Value="FormModel.Genere" class="form-control">
                        <option value="">Seleziona</option>
                        <option value="1">M</option>
                        <option value="2">F</option>
                    </InputSelect>
                </div>
            </fieldset>

            <button type="button" class="no-border btn-edit @((!IsReadOnly || IsSubmitting) ? "hidden" : "")" @onclick="Modifica">
                <span class="btn-text">Modifica</span>
                <img src="images/edit.svg" class="btn-icon" />
            </button>

            <button type="button" class="no-border btn-edit mobile-fab fab-tertiary btn-delete @((IsReadOnly || FormModel.IdBambino == null) ? "hidden" : "")" @onclick="Elimina">
                <span class="btn-text">Elimina</span>
                <img src="images/trash.svg" class="btn-icon" />
            </button>

            <button type="button" class="no-border btn-edit mobile-fab fab-secondary @((IsReadOnly || FormModel.IdBambino == null) ? "hidden" : "")" style="margin-left: 0" @onclick="AnnulaModifica">
                <span class="btn-text">Annulla</span>
                <img src="images/undo.svg" class="btn-icon" />
            </button>
        </div>

        <fieldset disabled="@IsReadOnly" class="no-border">

            <div class="row-flex mt">
                <div class="field medium">
                    <label>Luogo di nascita</label>
                    <InputText @bind-Value="FormModel.LuogoNascita" class="form-control" />
                </div>

                <div class="field large">
                    <label>Indirizzo di residenza</label>
                    <InputText @bind-Value="FormModel.IndirizzoResidenza" class="form-control" />
                </div>

                <div class="field medium">
                    <label>Comune di residenza</label>
                    <InputText @bind-Value="FormModel.ComuneResidenza" class="form-control" />
                </div>
            </div>

            <!-- ================= GENITORI ================= -->
            <div class="section mt">
                <label>Genitori</label>
                <button type="button" class="mb btn-add-genitore @((IsReadOnly || FormModel.Genitori.Count >= 2) ? "hidden" : "")" @onclick="AddGenitore">
                    Aggiungi Genitore
                </button>

                @if (FormModel.Genitori != null)
                {
                    @foreach (var genitore in FormModel.Genitori)
                    {
                        <div class="genitore-card">
                            <div class="field small center">
                                <InputText @bind-Value="genitore.Cognome" placeholder="Cognome" class="form-control" />
                            </div>

                            <div class="field small center">
                                <InputText @bind-Value="genitore.Nome" placeholder="Nome" class="form-control" />
                            </div>

                            <div class="field small center">
                                <InputText @bind-Value="genitore.Telefono" placeholder="Telefono" class="form-control" />
                            </div>

                            <div class="field small center">
                                <InputSelect @bind-Value="genitore.Genere" class="form-control">
                                    <option value="">Seleziona</option>
                                    <option value="1">M</option>
                                    <option value="2">F</option>
                                </InputSelect>
                            </div>

                            <button type="button" class="icon-button @(IsReadOnly ? "hidden" : "")" @onclick="@(() => ApriPopup(genitore))" title="Cerca genitore">
                                <img src="images/icona_cerca.svg" class="cerca-img" />
                            </button>

                            <button type="button" class="btn-remove @(IsReadOnly ? "hidden" : "")" @onclick="@(() => RemoveGenitore(FormModel.Genitori.IndexOf(genitore)))">
                                Rimuovi
                            </button>
                        </div>
                    }
                }
            </div>

            <!-- ================= ISCRIZIONE E NOTE ================= -->
            <div class="row-flex mt">
                <div class="field medium">
                    <label>Anno scolastico</label>
                    <InputSelect @bind-Value="FormModel.AnnoScolastico" class="form-control">
                        <option value="">Seleziona</option>
                        @foreach (var anno in AnniScolastici)
                        {
                            <option value="@anno.Value">@anno.Description</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="row-flex mt">
                <div class="field large">
                    <label>Note</label>
                    <InputTextArea @bind-Value="FormModel.Note" rows="3" class="form-control" />
                </div>
            </div>

            <!-- ================= SETTIMANE ================= -->
            @if (FormModel.Settimane != null)
            {
                <div class="section mt">
                    <label>Settimane</label>
                    @foreach (var settimana in FormModel.Settimane)
                    {
                        <div class="row-flex align-center">
                            <InputCheckbox @bind-Value="settimana.IsSelected" />
                            <span>@settimana.Desc</span>
                        </div>
                    }
                </div>
            }

            <!-- ================= TAGLIA ================= -->
            @if (Taglie != null)
            {
                <div class="row-flex mt">
                    <div class="field medium">
                        <label>Taglia</label>
                        <InputSelect @bind-Value="FormModel.Taglia" class="form-control">
                            <option value="">Seleziona</option>
                            @foreach (var taglia in Taglie)
                            {
                                <option value="@taglia.Id">@taglia.Descrizione</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            }

            <!-- ================= SCHEDA SANITARIA ================= -->
            <div class="row-flex mt">
                <div class="field large">
                    <label>Allergie/Intolleranze</label>
                    <InputTextArea @bind-Value="FormModel.AllergieIntolleranze" class="form-control" rows="2" />
                </div>
            </div>

            <div class="row-flex mt">
                <div class="field large">
                    <label>Patologie/Terapie</label>
                    <InputTextArea @bind-Value="FormModel.PatologieTerapie" class="form-control" rows="2" />
                </div>
            </div>

            <!-- ================= CONSENSI ================= -->
            @if (FormModel.ConsensiDisponibili != null)
            {
                <div class="section mt">
                    <label>Consensi</label>
                    @foreach (var consenso in FormModel.ConsensiDisponibili)
                    {
                        <div class="row-flex align-center">
                            <InputCheckbox @bind-Value="consenso.IsSelected" />
                            <span>@consenso.Descrizione</span>
                        </div>
                    }
                </div>
            }

            <!-- ================= PAGAMENTO E FLAGS ================= -->
            <div class="row-flex mt wrap">
                <div class="field medium">
                    <label>Formato iscrizione</label>
                    <InputSelect @bind-Value="FormModel.FormatoIscrizioneSelezionato">
                        <option value="">Seleziona</option>
                        @foreach (var formato in FormatoIscrizioneItems)
                        {
                            <option value="@formato.Id">@formato.Desc</option>
                        }
                    </InputSelect>
                </div>

                <div class="field medium">
                    <label>Modalità pagamento</label>
                    <InputSelect @bind-Value="FormModel.ModalitaPagamentoSelezionata">
                        <option value="">Seleziona</option>
                        @foreach (var modalita in ModalitaPagamentoItems)
                        {
                            <option value="@modalita.Id">@modalita.Desc</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="row-flex mt align-center">
                <InputCheckbox @bind-Value="FormModel.EsceSolo" />
                <span>Uscita autonoma</span>
            </div>

            <div class="row-flex mt align-center">
                <InputCheckbox @bind-Value="FormModel.DaIscrivereAlNoi" />
                <span>Da iscrivere al NOI</span>
            </div>

            <div class="row-flex mt align-center">
                <InputCheckbox @bind-Value="FormModel.ScontoFratelli" />
                <span>Sconto fratelli</span>
            </div>

            <div class="row-flex mt align-center">
                <InputCheckbox @bind-Value="FormModel.Ricevuta" />
                <span>Richiede ricevuta</span>
               
            </div>
            @if (FormModel.Ricevuta)
            {
            <div class="row-flex mt align-center">


                        <div class="field medium">
                            <label>Intestatario ricevuta</label>
                            <InputText @bind-Value="FormModel.DescRicevuta" class="form-control" />
                        </div>
                        </div>
            }
        </fieldset>

        <!-- ================= SUBMIT ================= -->
        <button type="submit"
        class="btn-submit mobile-fab @((IsReadOnly && !IsSubmitting) ? "hidden" : "")"
        disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <span class="btn-text visually-hidden">Salva iscrizione</span>
                <span class="save-loader"></span>
            }
            else
            {
                <span class="btn-text">Salva iscrizione</span>
                <img src="images/save.svg" class="btn-icon" />
            }
        </button>
    </div>
</EditForm>
@if (IsPopupAperto)
{
    <div class="popup-overlay">
        <div class="popup">

            <button @onclick="ChiudiPopup" class="popup-close">×</button>

            <h3>Seleziona un genitore</h3>

            @if (IsLoadingGenitori)
            {
                <div class="popup-loader">
                    <div class="loader"></div>
                </div>
            }
            else
            {
                <InputText Value="@_filtroGenitore"
                           ValueExpression="() => _filtroGenitore"
                           placeholder="Cerca per nome o cognome"
                           class="popup-search"
                           @oninput="OnFiltroGenitoreInput" />

                <div style="height:350px; overflow:auto;">
                    @foreach (var g in GenitoriFiltrati)
                    {
                        <div @onclick="() => SelezionaGenitore(g)" class="rigaGenitorePopup">
                            <strong>@g.Cognome</strong> @g.Nome
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}
@if (deletedPopup)
{
    <div class="succeded-popup-overlay">
        <div class="succeded-popup-content">
            <h3>Eliminazione completata</h3>
            <p>L'iscrizione di @FormModel.Cognome @FormModel.Nome è stata eliminata</p>
            <div class="popup-buttons">
                <button class="btn-no" @onclick="ChiudiMainPopup">Ok</button>
            </div>
        </div>
    </div>
}
@if (showErrorPopup)
{
    <div class="error-popup-overlay">
        <div class="error-popup-content">
            <button class="error-popup-close" @onclick="CloseErrorPopup">×</button>
            <h3>Errore durante il salvataggio</h3>
            <p style="white-space: pre-wrap;">@errorMessage</p>
        </div>
    </div>
}


@code {
    private LoadingView? LoadingOverlay;
    private bool IsLoading = true;
    [Parameter]
    public bool IsSubmitting { get; set; } = false;
    [Parameter]
    public ModuloIscrizioneDto FormModel { get; set; } = new();

    [Parameter]
    public EventCallback<ModuloIscrizioneDto> OnSubmitCallback { get; set; }

    [Parameter]
    public EventCallback ChiudiMainPopup { get; set; }

    [Inject]
    public ModuloIscrizioneViewModel ViewModel { get; set; } = new();

    [Parameter]
    public bool IsReadOnly { get; set; } = false;
    private List<Settimana>? Settimane = new List<Settimana>();
    private List<Taglia>? Taglie = new List<Taglia>();
    private List<ConsensoDto>? ConsensiDisponibili = new List<ConsensoDto>();

    private List<AnnoScolasticoItem> AnniScolastici =
    Enum.GetValues(typeof(AnnoScolastico))
          .Cast<AnnoScolastico>()
          .Select(e => new AnnoScolasticoItem((int)e)).ToList();

    private List<ModalitaPagamentoItem> ModalitaPagamentoItems = Enum.GetValues(typeof(ModalitaPagamentoValues))
          .Cast<ModalitaPagamentoValues>()
          .Select(e => new ModalitaPagamentoItem() { Id = (int)e, Desc = e.ToString() }).ToList();

    private List<FormatoIscrizioneItem> FormatoIscrizioneItems = Enum.GetValues(typeof(FormatoIscrizioneValues))
        .Cast<FormatoIscrizioneValues>()
        .Select(e => new FormatoIscrizioneItem() { Id = (int)e, Desc = e.ToString() }).ToList();
    private bool datiCaricati = false;

    private ModuloIscrizioneDto? _initialFormModel;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if(!Settimane.Any())
            Settimane = await ViewModel.GetSettimaneAsync();

        if (!Taglie.Any())
            Taglie = await ViewModel.GetTaglieAsync();

        if (!firstRender || datiCaricati){
            return;
        }

        IsLoading = true;
        StateHasChanged();

        LoadingOverlay?.Start();

        ConsensiDisponibili = await ViewModel.GetConsensiAsync();

        // Se i dati del FormModel arrivano da fuori (iscrizioneDaModificare), non sovrascriverli
        if (FormModel.Settimane == null || !FormModel.Settimane.Any())
        {
            FormModel.Settimane = Settimane.Select(s => new Settimana
                {
                    Id = s.Id,
                    Desc = s.Desc,
                    CostoBase = s.CostoBase,
                    CostoIntero = s.CostoIntero,
                    DataInizio = s.DataInizio,
                    DataFine = s.DataFine,
                    IsSelected = false
                }).ToList();
        }

        if (FormModel.ConsensiDisponibili == null || !FormModel.ConsensiDisponibili?.Any() == true)
            FormModel.ConsensiDisponibili = ConsensiDisponibili;

        IsReadOnly = FormModel.IdIscrizione != null;
        _initialFormModel = JsonConvert.DeserializeObject<ModuloIscrizioneDto>(
            JsonConvert.SerializeObject(FormModel)
            );
        datiCaricati = true;
        LoadingOverlay?.Stop();
        IsLoading = false;

        StateHasChanged();
    }

    private void AddGenitore()
    {
        FormModel.Genitori.Add(new GenitoreDto());
    }

    private void RemoveGenitore(int index)
    {
        FormModel.Genitori.RemoveAt(index);
    }

    private async Task HandleSubmit()
    {
        if (OnSubmitCallback.HasDelegate)
        {
            await OnSubmitCallback.InvokeAsync(FormModel);
        }
    }

    private bool IsPopupAperto = false;
    private bool IsLoadingGenitori = false;
    private List<GenitoreDto> Genitori = new(); // Lista completa dei genitori
    private string _filtroGenitore = string.Empty;

    private void OnFiltroGenitoreInput(ChangeEventArgs e)
    {
        _filtroGenitore = e.Value?.ToString() ?? string.Empty;
    }

    private List<GenitoreDto> GenitoriFiltrati =>
        string.IsNullOrWhiteSpace(_filtroGenitore)
            ? Genitori
            : Genitori.Where(g => g.Nome.Contains(_filtroGenitore, StringComparison.OrdinalIgnoreCase)
                                || g.Cognome.Contains(_filtroGenitore, StringComparison.OrdinalIgnoreCase)).ToList();

    private GenitoreDto? genitoreCorrente;

    private async void ApriPopup(GenitoreDto genitore)
    {
        genitoreCorrente = genitore;
        IsPopupAperto = true;
        IsLoadingGenitori = true;

        // Chiamata asincrona per caricare i genitori
        Genitori = await ViewModel.GetGenitoriListAsync();

        IsLoadingGenitori = false;
        StateHasChanged();
    }

    private void ChiudiPopup()
    {
        IsPopupAperto = false;
        _filtroGenitore = "";
        Genitori.Clear();
    }

    private void SelezionaGenitore(GenitoreDto genitore)
    {
        if (genitoreCorrente != null)
        {
            genitoreCorrente.IdGenitore = genitore.IdGenitore;
            genitoreCorrente.Nome = genitore.Nome;
            genitoreCorrente.Cognome = genitore.Cognome;
            genitoreCorrente.Telefono = genitore.Telefono;
            genitoreCorrente.Existing = true;
            genitoreCorrente.Genere = genitore.Genere;
        }
        IsPopupAperto = false;
        _filtroGenitore = "";
        Genitori.Clear();
    }

    private void Modifica()
    {
        IsReadOnly = false;
    }

    private void AnnulaModifica()
    {
        if (_initialFormModel != null)
        {
            // Deep clone again to avoid referencing the same object
            FormModel = JsonConvert.DeserializeObject<ModuloIscrizioneDto>(
                JsonConvert.SerializeObject(_initialFormModel)
            );
        }

        IsReadOnly = true;
    }

    private bool deletedPopup = false;
    private bool showErrorPopup = false;
    private string errorMessage = string.Empty;

    private async Task Elimina()
    {
        IsSubmitting = true; // disabilita il form
        IsReadOnly = true;

        bool succeded = false;
        try
        {
            succeded = await IscrizioneCompletaController.DeleteAsync(FormModel.IdBambino.Value);

            if (succeded)
            {
                deletedPopup = true; // mostra popup di successo
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message; // salva il messaggio da mostrare
            showErrorPopup = true;      // mostra popup
            Console.WriteLine($"Errore durante il salvataggio: {ex.Message}");
        }

        IsSubmitting = false;
        IsReadOnly = false;
    }

    private void CloseErrorPopup()
    {
        showErrorPopup = false;
        errorMessage = string.Empty;
    }
}
